{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dtfprint",
  "main": "worker.js",
  "compatibility_date": "2026-06-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    { "binding": "CONTENT", "id": "69ad61bb836248e9a70778bb92b25e98" }
  ]
}
